# Django settings (django-environ)
# Copy to .env and set values. Do not commit .env.

DEBUG=on
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Optional: Database (defaults to SQLite if not set)
# DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/dbname
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname

# Optional: Allowed hosts (comma-separated; only used when DEBUG=False)
# ALLOWED_HOSTS=localhost,127.0.0.1,.example.com
