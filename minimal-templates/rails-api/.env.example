# Rails API (dotenv-rails). Copy to .env and set values. Do not commit .env.
RAILS_ENV=development

# Database (config/database.yml)
DATABASE_HOST=db
DATABASE_USER=root
DATABASE_PASSWORD=password
DATABASE_NAME=template-rails-api_development

# Redis (config/cable.yml) — optional
# REDIS_URL=redis://localhost:6379/1

# Docker Compose の db サービス用（compose 側で設定する場合は不要）
# MYSQL_ROOT_PASSWORD=password
