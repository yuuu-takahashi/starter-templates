{
  "name": "full-template-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "format": "prettier --ignore-path .gitignore --write .",
    "lint": "next lint",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:analyze": "NODE_ENV=production ANALYZE=true next build",
    "start:lhci": "next start -p 3000",
    "lint:fix": "next lint --fix",
    "lint:all": "yarn _lint && yarn _type-check",
    "lint:all:fix": "yarn _lint:fix",
    "type-check": "yarn _type-check",
    "_lint": "next lint",
    "_lint:fix": "next lint --fix",
    "_type-check": "tsc --noEmit --skipLibCheck",
    "test:watch": "vitest",
    "secret-lint": "secretlint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "PLAYWRIGHT_HEADLESS=false playwright test",
    "test:e2e:debug": "PLAYWRIGHT_HEADLESS=false PLAYWRIGHT_DEVTOOLS=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "markdownlint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "markdownlint:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lhci": "lhci autorun",
    "lhci:prod": "NODE_ENV=production lhci autorun",
    "markuplint": "markuplint \"src/**/*.tsx\"",
    "markuplint:fix": "markuplint --fix \"src/**/*.tsx\"",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "15.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@next/third-parties": "^15.2.9",
    "@sentry/nextjs": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "happy-dom": "^20.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.2.9",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^3.0.5",
    "@dotenvx/dotenvx": "^1.0.0",
    "@vanilla-extract/next-plugin": "^2.4.14",
    "@vanilla-extract/vite-plugin": "^5.1.0",
    "@playwright/test": "^1.49.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^4.10.1",
    "eslint-plugin-storybook": "^0.11.0",
    "eslint-plugin-unused-imports": "^4.1.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^5.0.0",
    "lint-staged": "^16.1.2",
    "markdownlint-cli2": "^0.18.1",
    "msw": "^2.10.4",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "secretlint": "^11.3.1",
    "@chromatic-com/storybook": "^4.0.0",
    "@storybook/addon-a11y": "^9.0.0",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/addon-onboarding": "^9.0.0",
    "@storybook/nextjs-vite": "^9.0.0",
    "storybook": "^9.0.0",
    "@lhci/cli": "^0.14.0",
    "markuplint": "^4.0.0",
    "@markuplint/react-spec": "^4.0.0",
    "@markuplint/jsx-parser": "^4.0.0",
    "vite": "^6.0.0",
    "vitest-axe": "^0.1.0",
    "webpack-bundle-analyzer": "^5.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,css.ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
