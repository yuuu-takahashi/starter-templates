# ============================================
# 環境変数の分類と扱い方
# ============================================
#
# 【種類0: ビルドプロセス制御】
# - ビルドツール自体の動作を制御
# - 通常はNext.jsが自動設定（NODE_ENVなど）
#
# 【種類1: 公開設定値（NEXT_PUBLIC_*）】
# - ビルド時にクライアント側にバンドルされる
# - 機密情報は絶対に入れない
#
# 【種類2: サーバー設定値】
# - サーバー側のみで使用、公開しても問題ない値
#
# 【種類3: シークレット】
# - 機密情報、.env.exampleには変数名のみ記載

# ============================================
# 種類1: 公開設定値（NEXT_PUBLIC_*）
# ============================================
# ビルド時にクライアント側にバンドルされるため、機密情報は絶対に入れない
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# 種類2: サーバー設定値
# ============================================
# サーバー側のみで使用する設定値（公開しても問題ない値）
APP_ENV=development
LOG_LEVEL=debug

# ============================================
# 種類3: シークレット
# ============================================
# 機密情報は.env.local（開発環境）や環境変数（本番環境）で設定
# ここには変数名のみを記載（実際の値は記載しない）
# API_KEY=your-api-key-here
# DATABASE_PASSWORD=your-password-here

# ============================================
# Sentry エラートラッキング設定
# ============================================
# Sentry DSN（Data Source Name）
# 本番環境のみで有効化されます
# 取得方法: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://your-sentry-dsn@your-sentry-instance/your-project-id

# Sentry 環境（オプション）
# デフォルト: APP_ENV と同じ値
# SENTRY_ENVIRONMENT=production

# Sentry リリース版（オプション）
# デフォルト: development
# NEXT_PUBLIC_SENTRY_RELEASE=1.0.0
