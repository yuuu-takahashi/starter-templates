{
  "name": "full-template-nextjs",
  "scripts": {
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "secret-lint": "secretlint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "markdownlint": "markdownlint-cli2",
    "markdownlint:fix": "markdownlint-cli2 --fix",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lhci": "lhci autorun",
    "markuplint": "markuplint 'src/**/*.tsx'",
    "markuplint:fix": "markuplint --fix 'src/**/*.tsx'",
    "prepare": "husky"
  },
  "dependencies": {
    "@next/third-parties": "^15.2.3",
    "@sentry/nextjs": "^9.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.0.0",
    "@playwright/test": "^1.49.0",
    "husky": "^9.1.7",
    "knip": "^5.0.0",
    "lint-staged": "^16.1.2",
    "markdownlint-cli2": "^0.18.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "secretlint": "^11.3.1",
    "@chromatic-com/storybook": "^3.2.5",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-docs": "^8.6.0",
    "@storybook/addon-onboarding": "^8.6.0",
    "@storybook/addon-vitest": "^8.6.0",
    "@storybook/nextjs-vite": "^8.6.0",
    "storybook": "^8.6.0",
    "@lhci/cli": "^0.14.0",
    "markuplint": "^4.0.0",
    "@markuplint/react-spec": "^4.0.0",
    "@markuplint/react-parser": "^4.0.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,css.ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
