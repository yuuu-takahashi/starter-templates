{
  "name": "starter-templates",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky install",
    "create-project": "tsx scripts/select-template.ts",
    "dev:minimal:nextjs": "cd minimal-templates/nextjs && yarn dev",
    "dev:minimal:react": "cd minimal-templates/react && yarn dev",
    "dev:minimal:nodejs": "cd minimal-templates/nodejs && yarn dev",
    "dev:minimal:rails": "cd minimal-templates/rails && bin/rails server -p 3003",
    "dev:minimal:rails-api": "cd minimal-templates/rails-api && bin/rails server -p 3004",
    "dev:minimal:ruby": "cd minimal-templates/ruby && ruby lib/hello.rb",
    "dev:minimal:sinatra": "cd minimal-templates/sinatra && PORT=3007 bundle exec ruby index.rb",
    "dev:minimal": "concurrently \"yarn dev:minimal:nextjs\" \"yarn dev:minimal:react\" \"yarn dev:minimal:nodejs\" \"yarn dev:minimal:rails\" \"yarn dev:minimal:rails-api\" \"yarn dev:minimal:ruby\" \"yarn dev:minimal:sinatra\"",
    "dev:full:nextjs": "cd full-templates/nextjs && yarn dev",
    "dev:full:rails-api": "cd full-templates/rails-api && bin/rails server -p 3008",
    "dev:full": "concurrently \"yarn dev:full:nextjs\" \"yarn dev:full:rails-api\"",
    "dev": "concurrently \"yarn dev:minimal\" \"yarn dev:full\"",
    "kill:dev-ports": "bash scripts/kill-dev-ports.sh",
    "predev": "bash scripts/kill-dev-ports.sh",
    "generate:ci": "tsx scripts/generate-root-workflow.ts",
    "generate:devcontainer": "tsx scripts/generate-devcontainer.ts",
    "devcontainer": "devcontainer",
    "generate:configs": "tsx scripts/generate-configs.ts",
    "generate:deps": "tsx scripts/generate-deps.ts",
    "generate:lockfiles": "tsx scripts/generate-lockfiles.ts",
    "generate:all": "yarn generate:configs && yarn generate:deps && yarn generate:ci && yarn generate:devcontainer",
    "setup:templates": "tsx scripts/setup-templates.ts",
    "test": "vitest run",
    "lint": "eslint scripts/ && yarn lint:md",
    "lint:fix": "eslint scripts/ --fix",
    "lint:md": "markdownlint '**/*.md' --ignore '**/node_modules/**' --ignore '**/vendor/bundle/**'",
    "lint:md:fix": "markdownlint '**/*.md' --ignore '**/node_modules/**' --ignore '**/vendor/bundle/**' --fix",
    "format": "prettier --write \"scripts/**/*.ts\""
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.83.0",
    "@eslint/js": "^9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "concurrently": "^9",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "handlebars": "^4.7.9",
    "husky": "^9",
    "lint-staged": "^15",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.4.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8",
    "vitest": "^3.0.5",
    "yaml": "^2.6.1"
  },
  "lint-staged": {
    "scripts/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.md": [
      "markdownlint --fix"
    ]
  }
}
