{
  "name": "starter-templates",
  "private": true,
  "type": "module",
  "scripts": {
    "create-project": "tsx scripts/commands/select-template.ts",
    "generate:ci": "tsx scripts/commands/generate-root-workflow.ts",
    "generate:devcontainer": "tsx scripts/commands/generate-devcontainer.ts",
    "devcontainer": "devcontainer",
    "generate:configs": "tsx scripts/commands/generate-configs.ts",
    "generate:deps": "tsx scripts/commands/generate-deps.ts",
    "generate:all": "yarn generate:configs && yarn generate:deps && yarn generate:ci && yarn generate:devcontainer",
    "test": "vitest run",
    "lint": "eslint scripts/ && yarn lint:md",
    "lint:fix": "eslint scripts/ --fix",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint:md:fix": "markdownlint '**/*.md' --ignore node_modules --fix",
    "format": "prettier --write \"scripts/**/*.ts\""
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.83.0",
    "@eslint/js": "^9",
    "@types/node": "^22.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "handlebars": "^4.7.8",
    "prettier": "^3.4.2",
    "tsx": "^3.14.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8",
    "markdownlint-cli": "^0.48.0",
    "vitest": "^3.0.5",
    "yaml": "^2.6.1"
  }
}
